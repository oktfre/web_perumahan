# ── Server
PORT=3000
NODE_ENV=development

# ── PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=db_perumahan
DB_USER=postgres
DB_PASSWORD=123456
DB_MAX_CONN=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONN_TIMEOUT_MS=2000

# ── CORS (pisah koma jika lebih dari satu origin)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001

# ── Rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ── JWT
JWT_SECRET=havenest_super_secret_ganti_ini_di_production_min_32_karakter
JWT_EXPIRES=8h
JWT_REFRESH=7d

# ── Default Admin (untuk seed-admin.js)
ADMIN_EMAIL=admin@havenest.id
ADMIN_PASSWORD=Admin@123
